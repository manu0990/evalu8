{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "WS_PORT",
    "NEXT_PUBLIC_WS_SERVER_URL",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "AWS_REGION",
    "AWS_S3_BUCKET_NAME",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "WEB_LLM_API_KEY",
    "WEB_LLM_MODEL",
    "WS_LLM_API_KEY",
    "WS_LLM_BASE_URL",
    "WS_LLM_MODEL",
    "WS_LLM_TEMPERATURE",
    "WS_LLM_MAX_TOKENS",
    "CARTESIA_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "env": [
        "DATABASE_URL",
        "NEXT_PUBLIC_WS_SERVER_URL",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "AWS_REGION",
        "AWS_S3_BUCKET_NAME",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "WEB_LLM_API_KEY",
        "WEB_LLM_MODEL",
        "WS_LLM_API_KEY",
        "WS_LLM_BASE_URL",
        "WS_LLM_MODEL",
        "WS_LLM_TEMPERATURE",
        "WS_LLM_MAX_TOKENS",
        "CARTESIA_API_KEY"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "env": [
        "DATABASE_URL",
        "NEXT_PUBLIC_WS_SERVER_URL",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "AWS_REGION",
        "AWS_S3_BUCKET_NAME",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "WEB_LLM_API_KEY",
        "WEB_LLM_MODEL",
        "WS_LLM_API_KEY",
        "WS_LLM_BASE_URL",
        "WS_LLM_MODEL",
        "WS_LLM_TEMPERATURE",
        "WS_LLM_MAX_TOKENS",
        "CARTESIA_API_KEY"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ],
      "env": [
        "DATABASE_URL",
        "NEXT_PUBLIC_WS_SERVER_URL",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "AWS_REGION",
        "AWS_S3_BUCKET_NAME",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "WEB_LLM_API_KEY",
        "WEB_LLM_MODEL",
        "WS_LLM_API_KEY",
        "WS_LLM_BASE_URL",
        "WS_LLM_MODEL",
        "WS_LLM_TEMPERATURE",
        "WS_LLM_MAX_TOKENS",
        "CARTESIA_API_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "NEXT_PUBLIC_WS_SERVER_URL",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "AWS_REGION",
        "AWS_S3_BUCKET_NAME",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "WEB_LLM_API_KEY",
        "WEB_LLM_MODEL",
        "WS_LLM_API_KEY",
        "WS_LLM_BASE_URL",
        "WS_LLM_MODEL",
        "WS_LLM_TEMPERATURE",
        "WS_LLM_MAX_TOKENS",
        "CARTESIA_API_KEY"
      ]
    }
  }
}