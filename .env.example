# ----------------------------
# App Environment
# ----------------------------
NODE_ENV="development"  # Environment mode: development | production

# ----------------------------
# Authentication (NextAuth)
# ----------------------------
NEXTAUTH_SECRET="your-nextauth-secret-here"  # Used to sign/encrypt JWTs (keep secure)
NEXTAUTH_URL="http://localhost:3000"        # Base URL of your app

# ----------------------------
# Database (PostgreSQL)
# ----------------------------
DATABASE_URL="postgresql://evalu8_user:evalu8_password@localhost:5432/evalu8_db"
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# ----------------------------
# OAuth Providers
# ----------------------------
# Google OAuth credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth credentials
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ----------------------------
# Web LLM (Frontend / Server-side calls)
# ----------------------------
WEB_LLM_API_KEY="your-gemini-api-key"       # API key for web-based LLM (e.g. Gemini)
WEB_LLM_MODEL="your-web-llm-model-name"     # Model name (e.g. gemini-pro)

# ----------------------------
# WebSocket Server (Realtime LLM)
# ----------------------------
WS_PORT=8080                               # WebSocket server port

WS_LLM_API_KEY="your-ws-llm-api-key"       # API key for WS LLM provider
WS_LLM_BASE_URL="your-llm-base-url"        # Base API endpoint
WS_LLM_MODEL="your-ws-llm-model-name"      # Model used in WS server

WS_LLM_TEMPERATURE=0.7                     # Creativity (0 = deterministic, 1 = random)
WS_LLM_MAX_TOKENS=2048                     # Max response length

# Public URL for frontend to connect to WS server
NEXT_PUBLIC_WS_SERVER_URL="ws://localhost:8080"

# ----------------------------
# Cartesia (Voice / Audio API)
# ----------------------------
CARTESIA_API_KEY="your-cartesia-api-key"
CARTESIA_VOICE_MODEL="your-cartesia-voice-model-id"

# ----------------------------
# AWS (S3 Storage)
# ----------------------------
AWS_REGION="your-aws-region"               # e.g. ap-south-1
AWS_S3_BUCKET_NAME="your-s3-bucket-name"   # S3 bucket for uploads

AWS_ACCESS_KEY_ID="your-access-key-id"     # AWS IAM access key
AWS_SECRET_ACCESS_KEY="your-secret-access-key"  # AWS IAM secret (keep private)

# ----------------------------
# Deepgram (Real-Time STT)
# ----------------------------
DEEPGRAM_API_KEY="your-deepgram-api-key"   # Real-time speech-to-text
DEEPGRAM_STT_MODEL_NAME="your-stt-model-name"               # e.g. nova-3, or other Deepgram model