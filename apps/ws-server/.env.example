# ----------------------------
# Core App Config
# ----------------------------
NODE_ENV="development"  # App mode: development | production

# ----------------------------
# Database (PostgreSQL)
# ----------------------------
DATABASE_URL="postgresql://evalu8_user:evalu8_password@localhost:5432/evalu8_db"

# ----------------------------
# WebSocket Server
# ----------------------------
WS_PORT=8080  # Port for realtime server (LLM streaming, etc.)

# ----------------------------
# LLM Provider (OpenAI-compatible)
# ----------------------------
WS_LLM_API_KEY="your-ws-llm-api-key"   # Required: API key for provider
WS_LLM_MODEL="your-ws-llm-model-name"  # Model ID (e.g. gpt-4o, gemini-1.5-pro, claude-3)

# Optional overrides
# Leave unset to use SDK defaults
# WS_LLM_BASE_URL="https://api.your-llm-provider.com/v1"  # Needed for non-OpenAI providers
# WS_LLM_TEMPERATURE=0.7   # Creativity control (0 = strict, 1 = diverse)
# WS_LLM_MAX_TOKENS=2048   # Max output length

# ----------------------------
# Cartesia (Voice / TTS API)
# ----------------------------
CARTESIA_API_KEY="your-cartesia-api-key"  # Required for voice features