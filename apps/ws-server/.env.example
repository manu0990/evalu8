WS_PORT=8080

# Any OpenAI-compatible provider (OpenAI, Gemini, Anthropic, etc.)
LLM_API_KEY="your_api_key_here"
LLM_MODEL="gemini-2.0-flash"

# Optional. Leave LLM_BASE_URL unset to use the OpenAI SDK default.
# LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2048

NODE_ENV="development"
