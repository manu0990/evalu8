# ----------------------------
# Core App
# ----------------------------
NODE_ENV="development"  # development | production

# ----------------------------
# Database (PostgreSQL)
# ----------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/db_name"

# ----------------------------
# Authentication (NextAuth)
# ----------------------------
NEXTAUTH_SECRET="nextauth-secret"        # Used for session encryption
NEXTAUTH_URL="http://localhost:3000"     # Base app URL

# ----------------------------
# OAuth Providers
# ----------------------------
GOOGLE_CLIENT_ID="example-google-client-id"
GOOGLE_CLIENT_SECRET="example-google-client-secret"

GITHUB_CLIENT_ID="example-github-client-id"
GITHUB_CLIENT_SECRET="example-github-client-secret"

# ----------------------------
# Web LLM (Frontend / API usage)
# ----------------------------
WEB_LLM_API_KEY="your-gemini-api-key"     # API key (Gemini / other)
WEB_LLM_MODEL="your-web-llm-model-name"   # Model name

# ----------------------------
# WebSocket (Public URL for client)
# ----------------------------
NEXT_PUBLIC_WS_SERVER_URL="ws://localhost:8080"
# Exposed to frontend (must be prefixed with NEXT_PUBLIC)

# ----------------------------
# Cartesia (Voice / TTS)
# ----------------------------
CARTESIA_API_KEY="your-cartesia-api-key"

# ----------------------------
# AWS (S3 Storage)
# ----------------------------
AWS_REGION="your-aws-region"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET_NAME="your-s3-bucket-name"